/* -- Core Widgets -- */
QWidget {
    background-color: transparent;
    border: none;
}
/* Suppress Qt's native blue focus rectangle on inputs â€” without this,
   the focus indicator lingers visibly when the cursor leaves a focused
   widget (e.g., a combobox that was clicked into and out of). */
QLineEdit, QComboBox, QTextEdit, QPlainTextEdit, QAbstractSpinBox,
QFrame, QAbstractScrollArea, QAbstractSlider, QProgressBar,
QAbstractButton {
    outline: none;
}
QWidget::item:selected {
    background-color: {BUTTON_HOVER};
}
QToolTip {
    background-color: {PANEL_BACKGROUND};
    color: {TEXT_COLOR};
    border: {BORDER_W} solid {BORDER_COLOR};
}
QWidget.centralWidget {
    background-color: {WINDOW_BACKGROUND};
    border: {BORDER_W} solid {BORDER_COLOR};
    color: {TEXT_COLOR};
}
QWidget.QLabel {
    background-color: {WIDGET_BACKGROUND};
    color: {TEXT_COLOR};
    border: {BORDER_W} solid {BORDER_COLOR};
    border-radius: {RADIUS};
    padding: 0px 1px 0px 1px;
}

/* -- Containers -- */
QStackedWidget {
    background-color: {PANEL_BACKGROUND};
}
QStackedWidget QFrame {
    background-color: {PANEL_BACKGROUND};
}
QToolBox {
    background-color: {PANEL_BACKGROUND};
    border: {BORDER_W} solid {BORDER_COLOR};
}
QToolBox::tab {
    background-color: none;
    color: {TEXT_COLOR};
    border: none;
    padding: 0px 0px 0px 0px;
    height: 11px;
}
QToolBox::tab:selected {
    background-color: {BUTTON_CHECKED};
    color: {TEXT_CHECKED};
}
QToolBox::tab:hover {
    background-color: none;
    color: {TEXT_HOVER};
}
QMainWindow {
    background-color: {WINDOW_BACKGROUND};
    border: {BORDER_W} solid {BORDER_COLOR};
}
QGroupBox {
    border: none;
    border-radius: {RADIUS};
    padding: 1px 1px 2px 1px;
    margin: 12px 0px 2px 0px;
    background-color: {WINDOW_BACKGROUND};
}
/* QGroupBox:hover {
    border: {BORDER_W} solid {BUTTON_HOVER};
} */
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 2px;
    padding-top: 0px;
    background-color: {PANEL_BACKGROUND};
    color: {TEXT_COLOR};
}
QGroupBox[class="CollapsableGroup"]::title:hover {
    color: {TEXT_HOVER};
}
QGroupBox[class="CollapsableGroup"]::indicator {
    width: 0px;
    height: 0px;
}
QGroupBox:disabled {
    color: {TEXT_DISABLED};
}
QGroupBox::title:disabled {
    color: {TEXT_DISABLED};
}

/* -- Menus -- */
QMenu {
    background-color: {WINDOW_BACKGROUND};
    border: {BORDER_W} solid {BORDER_COLOR};
    margin: 0px;
}
QMenu::item {
    padding: 0px 1px 0px 1px;
    border: none;
}
QMenu::item:disabled {
    color: {TEXT_DISABLED};
}
QMenu::item:selected {
    border-color: {BUTTON_CHECKED};
    background-color: {PANEL_BACKGROUND};
}
QMenu::icon:checked {
    background-color: gray;
    border: {BORDER_W} inset gray;
    position: absolute;
    top: 1px;
    right: 1px;
    bottom: 1px;
    left: 1px;
}
QMenu::separator {
    height: 2px;
    background-color: {PANEL_BACKGROUND};
    margin: 0px 5px 0px 10px;
}
QMenu::indicator {
    width: 13px;
    height: 13px;
}
QMenuBar {
    background-color: {PANEL_BACKGROUND};
    spacing: 1px;
}
QMenuBar::item {
    padding: 1px 4px;
    background-color: transparent;
    border-radius: {RADIUS};
}
QMenuBar::item:selected {
    background-color: {BUTTON_CHECKED};
}
QMenuBar::item:pressed {
    background-color: gray;
}

/* -- Buttons -- */
QAbstractButton {
    background-color: {WIDGET_BACKGROUND};
    color: {TEXT_COLOR};
    border-style: outset;
    border-radius: {RADIUS};
    border: {BORDER_W} solid {BORDER_COLOR};
    padding: 0px 1px 0px 1px;
    spacing: 1px;
    text-align: center;
}
QAbstractButton:hover {
    background-color: {BUTTON_HOVER};
    color: {TEXT_HOVER};
}
QAbstractButton:hover:checked {
    background-color: {BUTTON_CHECKED};
    color: {TEXT_HOVER};
}
QAbstractButton:enabled {
    color: {TEXT_COLOR};
}
QAbstractButton:disabled {
    color: {TEXT_DISABLED};
    background-color: {DISABLED_BACKGROUND};
    border: {BORDER_W} solid {DISABLED_BACKGROUND};
}
QAbstractButton:checked {
    background-color: {BUTTON_CHECKED};
    color: {TEXT_CHECKED};
}
QAbstractButton:checked:hover {
    background-color: {BUTTON_CHECKED};
    color: {TEXT_CHECKED};
}
QAbstractButton::indicator {
    width: 0px;
    height: 0px;
    border: none;
}
QAbstractButton::indicator::unchecked {
    image: none;
}
QAbstractButton::indicator:unchecked:hover {
    image: none;
}
QAbstractButton::indicator:unchecked:pressed {
    image: none;
}
QAbstractButton::indicator::checked {
    image: none;
}
QAbstractButton::indicator:checked:hover {
    image: none;
}
QAbstractButton::indicator:checked:pressed {
    image: none;
}
/* QCheckBox: Inherits from QAbstractButton */
QCheckBox:disabled {
    color: {TEXT_DISABLED};
}

/* QRadioButton: Inherits from QAbstractButton */
QRadioButton:disabled {
    color: {TEXT_DISABLED};
}
QPushButton#toggle_expand {
    border: none;
    padding: 0px 0px 0px 0px;
    background-color: {PANEL_BACKGROUND};
}
QPushButton:flat {
    border: none;
}
QPushButton:default {
    border-color: navy;
}
QToolButton[popupMode="1"] {
    padding-right: 2px;
}
QToolButton:open {
    background-color: dark gray;
}
QToolButton::menu-indicator {
    image: none;
    subcontrol-origin: padding;
    subcontrol-position: bottom right;
    padding: 0px 5px 5px 0px;
}
/* Hide QPushButton menu indicators to avoid stray dots next to icons */
QPushButton::menu-indicator {
    image: none;
    width: 0px;
    height: 0px;
    padding: 0px;
    margin: 0px;
    border: none;
    background: transparent;
    subcontrol-origin: padding;
    subcontrol-position: bottom right;
}

/* Extra-specific rules for our option buttons to override host styles */
QPushButton#pinButton::menu-indicator,
QPushButton#clearButton::menu-indicator,
QPushButton#actionButton::menu-indicator,
QPushButton#optionMenuButton::menu-indicator,
QPushButton#optionBox::menu-indicator,
QPushButton[class~="ActionButton"]::menu-indicator,
QPushButton[class~="BrowseButton"]::menu-indicator,
QPushButton[class~="RecentButton"]::menu-indicator,
QPushButton[class~="ClearButton"]::menu-indicator,
QPushButton[class~="PinButton"]::menu-indicator {
    image: none;
    width: 0px;
    height: 0px;
    padding: 0px;
    margin: 0px;
    border: none;
    background: transparent;
}

/* Option-box buttons â€” keep icon centered inside the 19x19 button.
   Class-based selectors survive _assign_option_object_name's rename. */
QPushButton[class~="ActionButton"],
QPushButton[class~="BrowseButton"],
QPushButton[class~="RecentButton"],
QPushButton[class~="ClearButton"],
QPushButton[class~="PinButton"] {
    padding: 0;
    margin: 0;
    text-align: center;
}

/* Within the option box container, suppress any menu indicators on buttons */
QWidget#optionBoxContainer QPushButton::menu-indicator {
    image: none;
    width: 0px;
    height: 0px;
    padding: 0px;
    margin: 0px;
    border: none;
    background: transparent;
}

/* Specific styling for option menu button to prevent any artifacts */
QPushButton#optionMenuButton {
    text-align: center;
    padding: 0px;
    padding-left: 0px;
    padding-right: 0px;
    margin: 0px;
    spacing: 0px;
    border-left-width: 0px;
    border-left-style: none;
}

QPushButton#optionMenuButton:hover {
    padding: 0px;
    padding-left: 0px;
    padding-right: 0px;
    margin: 0px;
}

/* Suppress all sub-controls that might cause artifacts */
QPushButton#optionMenuButton::menu-indicator,
QPushButton#optionMenuButton::menu-arrow,
QPushButton#optionMenuButton::down-arrow,
QPushButton[class~="OptionMenuButton"]::menu-indicator,
QPushButton[class~="OptionMenuButton"]::menu-arrow {
    image: none;
    width: 0px;
    height: 0px;
    padding: 0px;
    margin: 0px;
    border: none;
    background: transparent;
    subcontrol-origin: padding;
    subcontrol-position: center;
}

QToolButton::down-arrow,
QToolButton::up-arrow,
QToolButton::left-arrow,
QToolButton::right-arrow {
    image: none;
    padding: 0px 15px 0px 0px;
}
QToolButton::down-arrow:hover,
QToolButton::up-arrow:hover,
QToolButton::left-arrow:hover,
QToolButton::right-arrow:hover {
    padding: 0px 5px 0px 0px;
}
QToolButton::menu-button {
    border: {BORDER_W} solid {TEXT_COLOR};
    margin: 4px 2px 4px 0px;
}
QToolButton::menu-button:pressed {
    background-color: transparent;
    border: none;
}
QToolButton::menu-arrow {
    image: none;
}

/* -- Spin Boxes -- */
QAbstractSpinBox {
    background-color: {WIDGET_BACKGROUND};
    color: {TEXT_COLOR};
    border: {BORDER_W} solid {BORDER_COLOR};
}
QAbstractSpinBox:disabled {
    color: {TEXT_DISABLED};
    background-color: {DISABLED_BACKGROUND};
    border: {BORDER_W} solid {DISABLED_BACKGROUND};
}
QAbstractSpinBox:hover {
    border: {BORDER_W} solid {BORDER_HOVER};
}
QScrollBar:left-arrow,
QScrollBar::right-arrow,
QScrollBar::up-arrow,
QScrollBar::down-arrow {
    border: {BORDER_W} solid rgb(120,120,120);
    width: 3px;
    height: 3px;
}
QAbstractSpinBox::up-arrow,
QAbstractSpinBox::down-arrow {
    width: 0px;
    height: 0px;
    border: none;
    image: none;
}
QAbstractSpinBox::up-button,
QAbstractSpinBox::down-button {
    border: none;
    background: transparent;
    subcontrol-origin: border;
    width: 0px;
    height: 0px;
    margin: 0px;
    padding: 0px;
}
/* QSpinBox: Inherits from QAbstractSpinBox */
/* QDoubleSpinBox: Inherits from QAbstractSpinBox */

/* -- Combo Boxes -- */
QComboBox {
    background-color: {WIDGET_BACKGROUND};
    color: {TEXT_COLOR};
    border: {BORDER_W} solid {BORDER_COLOR};
    padding: 0px 1px 0px 1px;
    border-radius: {RADIUS};
}
QComboBox:disabled {
    color: {TEXT_DISABLED};
    background-color: {DISABLED_BACKGROUND};
    border: {BORDER_W} solid {DISABLED_BACKGROUND};
}
QComboBox:hover {
    background-color: {WIDGET_BACKGROUND_HOVER};
    border: {BORDER_W} solid {BORDER_HOVER};
}
QComboBox::open {
    selection-background-color: {WIDGET_BACKGROUND};
    selection-color: {TEXT_CHECKED};
}
QComboBox:on {
    padding-top: 3px;
    background-color: {WIDGET_BACKGROUND};
    border: {BORDER_W} solid {BORDER_COLOR};
}
QComboBox::down-arrow {
    width: 0px;
    height: 0px;
    background-color: {WIDGET_BACKGROUND};
    border: none;
    image: none;
}
QComboBox::drop-down {
    border: none;
    background-color: {WIDGET_BACKGROUND};
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 0px;
    height: 0px;
    border-left-width: {BORDER_W};
    border-left-color: {TEXT_CHECKED};
    border-left-style: solid;
    border-top-right-radius: {RADIUS};
    border-bottom-right-radius: {RADIUS};
}
QComboBox:disabled::drop-down {
    border-left-color: {DISABLED_BACKGROUND};
}
QComboBox QAbstractItemView {
    background-color: {WIDGET_BACKGROUND};
    selection-background-color: {BUTTON_HOVER};
    border: {BORDER_W} solid {BORDER_COLOR};
    padding: 1px;
    margin: 0px;
}
QComboBox QAbstractItemView::item {
    padding: 1px;
    border: none;
    min-height: 14px;
}
QComboBox QAbstractItemView::item:selected,
QComboBox QAbstractItemView::item:hover,
QComboBox QAbstractItemView::item:selected:hover {
    background-color: {BUTTON_HOVER};
    color: {TEXT_HOVER};
    padding: 1px;
    border: none;
}
/* Hide the 12px checkmark column inside combobox popups — Fusion reserves
   it on hover/selected and shifts text right by that amount. Tree/table
   views keep the indicator (rule at QAbstractItemView::indicator below). */
QComboBox QAbstractItemView::indicator {
    width: 0px;
    height: 0px;
    border: none;
}

/* -- Text and Input -- */
QLabel {
    background-color: {WIDGET_BACKGROUND};
    color: {TEXT_COLOR};
    border-style: none;
    border-radius: {RADIUS};
    border: {BORDER_W} solid {BORDER_COLOR};
    padding: 0px 0px 0px 2px;
}
QLabel:hover {
    background-color: {WIDGET_BACKGROUND};
    color: {TEXT_COLOR};
    border-style: none;
    border-radius: {RADIUS};
    border: {BORDER_W} solid {BORDER_COLOR};
}
QLabel[clickable="true"]:hover {
    background-color: {BUTTON_HOVER};
    color: {TEXT_HOVER};
    border-style: outset;
    border-radius: {RADIUS};
    border: {BORDER_W} solid {BORDER_COLOR};
}
QLabel:enabled {
    color: {TEXT_COLOR};
}
QLabel:disabled {
    color: {TEXT_DISABLED};
    background-color: {DISABLED_BACKGROUND};
    border: {BORDER_W} solid {DISABLED_BACKGROUND};
}
QLineEdit {
    background-color: {WIDGET_BACKGROUND};
    color: {TEXT_COLOR};
    border: {BORDER_W} solid {BORDER_COLOR};
    selection-background-color: {BUTTON_HOVER};
    selection-color: {TEXT_COLOR};
    border-radius: {RADIUS};
    padding: 0 8px;
}
QLineEdit:hover {
    border: {BORDER_W} solid {BORDER_HOVER};
}
QLineEdit:disabled {
    color: {TEXT_DISABLED};
    background-color: {DISABLED_BACKGROUND};
    border: {BORDER_W} solid {DISABLED_BACKGROUND};
}
QLineEdit:read-only:enabled {
    color: {TEXT_COLOR};
    background-color: {WIDGET_BACKGROUND};
    border: {BORDER_W} solid {BORDER_COLOR};
}
QLineEdit:read-only:hover {
    border: {BORDER_W} solid {BORDER_COLOR};
    color: {TEXT_COLOR};
}
QLineEdit:read-only:disabled {
    color: {TEXT_DISABLED};
    background-color: {DISABLED_BACKGROUND};
    border: {BORDER_W} solid {DISABLED_BACKGROUND};
}
/* Action state feedback (set via dynamic property) */
QLineEdit[actionState="valid"] {
    color: {ACTION_VALID_FG};
    background-color: {ACTION_VALID_BG};
}
QLineEdit[actionState="invalid"] {
    color: {ACTION_INVALID_FG};
    background-color: {ACTION_INVALID_BG};
}
QLineEdit[actionState="warning"] {
    color: {ACTION_WARNING_FG};
    background-color: {ACTION_WARNING_BG};
}
QLineEdit[actionState="info"] {
    color: {ACTION_INFO_FG};
    background-color: {ACTION_INFO_BG};
}
QLineEdit[actionState="inactive"] {
    color: {ACTION_INACTIVE_FG};
}
QTextEdit {
    color: {TEXT_COLOR};
    background-attachment: fixed;
    border: {BORDER_W} solid {BORDER_COLOR};
    background-color: {WIDGET_BACKGROUND};
}
QTextEdit:hover {
    border: {BORDER_W} solid {BORDER_HOVER};
}
QTextEdit:disabled {
    color: {TEXT_DISABLED};
    background-color: {DISABLED_BACKGROUND};
    border: {BORDER_W} solid {DISABLED_BACKGROUND};
}
QTextEdit QWidget#qt_scrollarea_viewport {
    background-color: {WIDGET_BACKGROUND};
}
QTextEdit#hudTextEdit {
    border: none;
    background-color: transparent;
    color: white;
    selection-background-color: {SELECTION_BG};
    selection-color: white;
}
QPlainTextEdit {
    background-color: {WIDGET_BACKGROUND};
    border: {BORDER_W} solid {BORDER_COLOR};
    color: {TEXT_COLOR};
}
QPlainTextEdit:hover {
    border: {BORDER_W} solid {BORDER_HOVER};
}
QPlainTextEdit:disabled {
    color: {TEXT_DISABLED};
    background-color: {DISABLED_BACKGROUND};
    border: {BORDER_W} solid {DISABLED_BACKGROUND};
}

/* -- Item Views --
   Default: standard blue selection fill (matches the theme's BUTTON_HOVER
   so it reads as the canonical "active" accent) and a white-tint hover.
   Editors whose cells carry colour-coded backgrounds â€” color swatches,
   tag chips, status palettes â€” can opt out by installing
   RowSelectionBorderDelegate, which mutes ``State_Selected`` and draws a
   row-spanning border so the cell colour bleeds through underneath. */
QAbstractItemView {
    alternate-background-color: {ALTERNATE_BACKGROUND};
    background-attachment: fixed;
    color: {TEXT_COLOR};
    outline: 0;
}
QAbstractItemView::item:alternate {
    background-color: {ALTERNATE_BACKGROUND};
}
QAbstractItemView::item:hover {
    background-color: rgba(255,255,255,50);
    color: {TEXT_HOVER};
}
QAbstractItemView::item:selected {
    background-color: {BUTTON_HOVER};
    color: {TEXT_HOVER};
    border: {BORDER_W} solid {BUTTON_HOVER};
}
QAbstractItemView::item:selected:hover {
    background-color: {BUTTON_HOVER};
    color: {TEXT_HOVER};
    border: {BORDER_W} solid {BUTTON_HOVER};
}
QAbstractItemView::item:checked {
    background-color: {BUTTON_CHECKED};
    color: {TEXT_COLOR};
}
QAbstractItemView::item:checked:selected {
    background-color: {BUTTON_CHECKED};
    color: {TEXT_CHECKED};
    border: {BORDER_W} solid {BUTTON_HOVER};
}
QAbstractItemView:disabled {
    color: {TEXT_DISABLED};
    background-color: {DISABLED_BACKGROUND};
}

QAbstractItemView::indicator {
    width: 12px;
    height: 12px;
    border: {BORDER_W} solid {BORDER_COLOR};
    background-color: {WIDGET_BACKGROUND};
}
QAbstractItemView::indicator:checked {
    background-color: {BUTTON_HOVER};
    border: 2px solid {BUTTON_HOVER};
}
/* QListWidget: Inherits from QAbstractItemView */
/* QListView: Inherits from QAbstractItemView */
/* QTableView: Inherits from QAbstractItemView */

QHeaderView::section {
    background-color: {WIDGET_BACKGROUND};
    color: {TEXT_COLOR};
    padding: 4px;
    border: none;
    font-weight: bold;
}

QTableCornerButton::section {
    background-color: {WIDGET_BACKGROUND};
    border: none;
}

/* Default QTableWidget â€” solid base background like TreeWidget, standard
   blue selection fill, and a white-tint hover. More specific than the
   QAbstractItemView rules above, so it overrides without affecting other
   item views. Editors that want the row-spanning outline style (with
   transparent selection so colour-coded cell backgrounds bleed through)
   replace the item delegate with RowSelectionBorderDelegate. */
QTableWidget {
    background-color: {WIDGET_BACKGROUND};
    alternate-background-color: {ALTERNATE_BACKGROUND};
    color: {TEXT_COLOR};
    selection-background-color: {BUTTON_HOVER};
    selection-color: {TEXT_HOVER};
    gridline-color: transparent;
    outline: 0;
}
QTableWidget::item {
    padding: 2px 5px;
    border: {BORDER_W} solid transparent;
}
QTableWidget::item:hover {
    background-color: rgba(255, 255, 255, 30);
    color: {TEXT_HOVER};
    border: {BORDER_W} solid transparent;
}
QTableWidget::item:selected {
    background-color: {BUTTON_HOVER};
    color: {TEXT_HOVER};
    border: {BORDER_W} solid {BUTTON_HOVER};
}
QTableWidget::item:selected:hover {
    background-color: {BUTTON_HOVER};
    color: {TEXT_HOVER};
    border: {BORDER_W} solid {BUTTON_HOVER};
}

QTreeView::branch {
    background-color: transparent;
    border: none;
    margin: 2px;
}
QTreeView::branch:has-siblings:!adjoins-item {
    background-color: transparent;
}
QTreeView::branch:has-siblings:adjoins-item {
    background-color: transparent;
}
QTreeView::branch:!has-children:!has-siblings:adjoins-item {
    background-color: transparent;
}
QTreeView::branch:has-children:closed {
    background-color: {WIDGET_BACKGROUND};
    border: {BORDER_W} solid {BORDER_COLOR};
    border-radius: 2px;
    width: 14px;
    height: 14px;
    margin: 1px;
}
QTreeView::branch:has-children:closed:hover {
    background-color: {BUTTON_HOVER};
}
QTreeView::branch:has-children:open {
    background-color: {WIDGET_BACKGROUND};
    border: {BORDER_W} solid {BORDER_COLOR};
    border-radius: 2px;
    width: 14px;
    height: 14px;
    margin: 1px;
}
QTreeView::branch:has-children:open:hover {
    background-color: {BUTTON_HOVER};
}

/* -- Frames -- */
QFrame {
    border-radius: {RADIUS};
}
QFrame:hover {
    border: {BORDER_W} solid {BORDER_HOVER};
}

/* -- Scroll Areas -- */
QAbstractScrollArea {
    background-color: {WIDGET_BACKGROUND};
    border: {BORDER_W} solid {BORDER_COLOR};
    selection-background-color: {BUTTON_HOVER};
    selection-color: {TEXT_COLOR};
}
QAbstractScrollArea:hover {
    border: {BORDER_W} solid {BORDER_HOVER};
}
QAbstractScrollArea:disabled {
    color: {TEXT_DISABLED};
    background-color: {DISABLED_BACKGROUND};
    border: {BORDER_W} solid {DISABLED_BACKGROUND};
}
/* QScrollArea: Inherits from QAbstractScrollArea */
/* QGraphicsView: Inherits from QAbstractScrollArea */
/* QMdiArea: Inherits from QAbstractScrollArea */

/* -- Sliders and Progress -- */
QAbstractSlider {
    border: {BORDER_W} solid {BORDER_COLOR};
    background-color: {WIDGET_BACKGROUND};
}
QAbstractSlider:hover {
    background-color: {WIDGET_BACKGROUND_HOVER};
    border: {BORDER_W} solid {BORDER_HOVER};
}
QAbstractSlider:disabled {
    color: {TEXT_DISABLED};
    background-color: {DISABLED_BACKGROUND};
    border: {BORDER_W} solid {DISABLED_BACKGROUND};
}
QAbstractSlider::handle:disabled {
    background-color: {DISABLED_BACKGROUND};
    border: {BORDER_W} solid {DISABLED_BACKGROUND};
}
QAbstractSlider::groove:disabled {
    background-color: {DISABLED_BACKGROUND};
    border: {BORDER_W} solid {DISABLED_BACKGROUND};
}
QAbstractSlider::handle {
    width: 10px;
    margin-top: -6px;
    margin-bottom: -6px;
    border: {BORDER_W} solid {BORDER_COLOR};
    /* Literal 1px: handle is width:10px by design â€” {RADIUS} > 5 distorts it. */
    border-radius: 1px;
    background-color: {PANEL_BACKGROUND};
}
QAbstractSlider::handle:hover {
    background-color: {BUTTON_HOVER};
}
QAbstractSlider::groove {
    border: {BORDER_W} solid {BORDER_COLOR};
    height: 8px;
    background-color: {WIDGET_BACKGROUND};
}
QAbstractSlider::sub-page {
    background-color: {WIDGET_BACKGROUND};
}
QAbstractSlider::add-page {
    background-color: {WIDGET_BACKGROUND};
}
/* QSlider: Inherits from QAbstractSlider */
/* Scrollbar: 10px track (invisible), thin handle via margin, expands on hover */
QScrollBar:vertical {
    background: transparent;
    border: none;
    width: 10px;
    margin: 0px;
}
QScrollBar:horizontal {
    background: transparent;
    border: none;
    height: 10px;
    margin: 0px;
}
QScrollBar::handle:vertical {
    background: {BUTTON_CHECKED};
    min-height: 20px;
    border: none;
    border-radius: 2px;
    margin: 0px 3px;
}
QScrollBar::handle:horizontal {
    background: {BUTTON_CHECKED};
    min-width: 20px;
    border: none;
    border-radius: 2px;
    margin: 3px 0px;
}
QScrollBar::handle:vertical:hover {
    background: {BUTTON_HOVER};
    border-radius: 4px;
    margin: 0px;
}
QScrollBar::handle:horizontal:hover {
    background: {BUTTON_HOVER};
    border-radius: 4px;
    margin: 0px;
}
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    border: none;
    background: transparent;
    height: 0px;
    width: 0px;
}
QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
    border: none;
    background: transparent;
    height: 0px;
    width: 0px;
}
QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
    background: transparent;
}
QScrollBar::add-page:horizontal, QScrollBar::sub-page:horizontal {
    background: transparent;
}

/* -- Progress Bar -- */
QProgressBar {
    border: {BORDER_W} solid {BORDER_COLOR};
    background-color: {PANEL_BACKGROUND};
}
QProgressBar:hover {
    background-color: {WIDGET_BACKGROUND_HOVER};
    border: {BORDER_W} solid {BORDER_HOVER};
}
QProgressBar:disabled {
    color: {TEXT_DISABLED};
    background-color: {DISABLED_BACKGROUND};
    border: {BORDER_W} solid {DISABLED_BACKGROUND};
}
QProgressBar::chunk:disabled {
    background-color: {TEXT_DISABLED};
}
QProgressBar[orientation="Qt::Horizontal"] {
    padding-right: 10000px;
    text-align: right;
}
QProgressBar[orientation="Qt::Vertical"] {
    padding-top: 10000px;
    text-align: top;
}
QProgressBar::chunk {
    background-color: {PROGRESS_BAR_COLOR};
    width: 10px;
    margin: 0.5px;
}

/* -- Size Grip -- */
QSizeGrip,
QSizeGrip[class~="SizeGrip"] {
    background: transparent;
    border: none;
    width: 12px;
    height: 12px;
    image: none;
    qproperty-baseColor: rgba(255, 255, 255, 100);
    qproperty-hoverColor: {BUTTON_HOVER};
}

.MenuStatusBar {
    background-color: {WINDOW_BACKGROUND};
    border: none;
    color: {TEXT_COLOR};
}
.MenuStatusBar QLabel,
.MenuStatusBar QPushButton,
.MenuStatusBar QToolButton {
    background: transparent;
    border: none;
    color: {TEXT_COLOR};
}
.MenuStatusBar QLabel:hover,
.MenuStatusBar QPushButton:hover,
.MenuStatusBar QToolButton:hover {
    background: transparent;
    color: {TEXT_COLOR};
}
.MenuStatusBar QLabel:pressed,
.MenuStatusBar QPushButton:pressed,
.MenuStatusBar QToolButton:pressed {
    background: transparent;
    color: {TEXT_COLOR};
}


/* -- Custom Classes -- */
.default {
    background-color: {WIDGET_BACKGROUND};
    color: {TEXT_COLOR};
    border-style: outset;
    border-radius: {RADIUS};
    border: {BORDER_W} solid {BORDER_COLOR};
    padding: 0px 1px 0px 1px;
    spacing: 1px;
}
.default:hover {
    background-color: {BUTTON_HOVER};
    color: {TEXT_HOVER};
}
.default:hover:checked {
    background-color: {BUTTON_CHECKED};
    color: {TEXT_HOVER};
}
.default:enabled {
    color: {TEXT_COLOR};
}
.default:disabled {
    color: {TEXT_DISABLED};
    background-color: {DISABLED_BACKGROUND};
    border: {BORDER_W} solid {DISABLED_BACKGROUND};
}
.transparentBgNoBorder {
    background-color: transparent;
    border: none;
    color: {TEXT_COLOR};
    selection-background-color: {SELECTION_BG};
    selection-color: {SELECTION_FG};
}
.translucentBgNoBorder {
    background-color: rgba(127,127,127,0.004);
    border: none;
    color: {TEXT_COLOR};
    selection-background-color: {SELECTION_BG};
    selection-color: {SELECTION_FG};
}
.translucentBgWithBorder {
    background-color: {WINDOW_BACKGROUND};
    border: {BORDER_W} solid {BORDER_COLOR};
    color: {TEXT_COLOR};
    selection-background-color: {SELECTION_BG};
    selection-color: {SELECTION_FG};
}
.translucentBgWithBorder:hover {
    border: {BORDER_W} solid {BORDER_COLOR};
}
.translucentBgWithBorder QAbstractItemView::item:hover {
    background-color: transparent;
    color: {TEXT_COLOR};
}
.bgWithBorder {
    background-color: {PANEL_BACKGROUND};
    border: {BORDER_W} solid {BORDER_COLOR};
    color: {TEXT_COLOR};
    selection-background-color: {SELECTION_BG};
    selection-color: {SELECTION_FG};
}
.noBorder {
    border: 0px none;
}
.withBorder {
    border: {BORDER_W} solid {BORDER_COLOR};
}

/* OptionBox Container Styling - Higher specificity to override QWidget rule */
QWidget#optionBoxContainer {
    border: {BORDER_W} solid {BORDER_COLOR} !important;
    padding: 0px;
    margin: 0px;
}

/* Unified hover frame: the wrapped widget's right border is stripped (see
   _apply_border_styling), so the container owns the right edge. Color matches
   the per-widget :hover (QLineEdit, QTextEdit, etc.) so the row reads as one
   control on hover. Scoped to withBorder so frameless variants stay borderless,
   and gated by wrappedEnabled (synced in _sync_option_buttons_enabled) so the
   row doesn't highlight when the wrapped widget or container is disabled. */
QWidget#optionBoxContainer[class~="withBorder"][wrappedEnabled="true"]:hover {
    border: {BORDER_W} solid {BORDER_HOVER} !important;
}

QPushButton#optionBox {
    border: {BORDER_W} solid {BORDER_COLOR};
    border-left-width: 0px; /* remove internal left divider */
    border-left-style: none;
    padding: 0px;
    padding-left: 0px;
    padding-right: 0px;
    margin: 0px;
    text-align: center;
    border-top-right-radius: 0px;
    border-bottom-right-radius: 0px;
    border-top-left-radius: 0px;
    border-bottom-left-radius: 0px;
}

/* Suppress any sub-controls on optionBox button that might create artifacts */
QPushButton#optionBox::menu-indicator,
QPushButton#optionBox::menu-arrow {
    image: none;
    width: 0px;
    height: 0px;
    padding: 0px;
    margin: 0px;
    border: 0px none transparent;
    background: transparent;
}

QWidget[class~="withBorder"] {
    border: {BORDER_W} solid {BORDER_COLOR} !important;
}
.noPadding {
    padding: 0px 0px 0px 0px;
}
.noHover:hover {
    background-color: {WIDGET_BACKGROUND};
}
.textBold {
    font-weight: bold;
}
Header {
    background-color: {PANEL_BACKGROUND};
    border: none;
    border-radius: {RADIUS};
}
Header:hover {
    background-color: {PANEL_BACKGROUND};
    border: none;
    border-radius: {RADIUS};
}
Header > QLabel {
    font-weight: bold;
    padding-left: 20px;
    color: {TEXT_COLOR};
}
Header > QPushButton {
    background-color: transparent;
    border: none;
}
Header > QPushButton:hover {
    background-color: {WINDOW_BACKGROUND};
    border: none;
}
Header > QPushButton:checked {
    background-color: {BUTTON_CHECKED};
    border: none;
}
Header > QPushButton:checked:hover {
    background-color: {BUTTON_CHECKED};
    border: none;
}
Header > QPushButton:pressed {
    background-color: {BUTTON_HOVER};
    border: none;
}
Header > QPushButton#hdr_hide:hover {
    background-color: red;
    border: none;
}
/* Footer widgets â€” transparent when footerWidget="true", normal otherwise */
[footerWidget="true"] {
    background-color: transparent;
    border: none;
}
[footerWidget="true"]:hover {
    background-color: {WINDOW_BACKGROUND};
    border: none;
}
[footerWidget="true"]:checked {
    background-color: {BUTTON_CHECKED};
    border: none;
}
[footerWidget="true"]:checked:hover {
    background-color: {BUTTON_CHECKED};
    border: none;
}
[footerWidget="true"]:pressed {
    background-color: {BUTTON_HOVER};
    border: none;
}
/* Footer widgets are slightly rounded by default; opt out with footerRounded="false".
   Selectors include the parent type to beat QAbstractButton (border-radius: {RADIUS}). */
Footer > QPushButton[footerRounded="true"],
Footer > QToolButton[footerRounded="true"],
Footer > QAbstractButton[footerRounded="true"],
Footer > QWidget[footerRounded="true"] {
    border-radius: 3px;
}
Footer > [footerRounded="false"],
Footer > QAbstractButton[footerRounded="false"] {
    border-radius: 0;
}

/* Menu & MainWindow custom widgets inherit translucent border styling */
Menu,
MainWindow {
    background-color: {WINDOW_BACKGROUND};
    border: {BORDER_W} solid {BORDER_COLOR};
    color: {TEXT_COLOR};
    selection-background-color: {SELECTION_BG};
    selection-color: {SELECTION_FG};
}

/* Menu Frame (inner container with border) */
QFrame#menuFrame {
    background-color: {WINDOW_BACKGROUND};
    border: {BORDER_W} solid {BORDER_COLOR};
    color: {TEXT_COLOR};
}
QFrame#menuFrame:hover {
    background-color: {WINDOW_BACKGROUND};
    border: {BORDER_W} solid {BORDER_COLOR};
}

/* Footer Styling */
Footer {
    background-color: {PANEL_BACKGROUND};
    border: none;
    border-radius: {RADIUS};
    color: {TEXT_COLOR};
}
Footer:hover {
    background-color: {PANEL_BACKGROUND};
    border: none;
    border-radius: {RADIUS};
}
Footer > QLabel {
    background: transparent;
    border: none;
    color: {TEXT_COLOR};
    padding-left: 8px;
}
Footer > QLabel:hover {
    background: transparent;
    border: none;
    color: {TEXT_COLOR};
}

/* -- TreeWidget Specific Styling -- */
QTreeWidget {
    outline: none;
    background-color: {WIDGET_BACKGROUND};
    color: {TEXT_COLOR};
    selection-background-color: {BUTTON_HOVER};
    show-decoration-selected: 1;
    gridline-color: transparent;
    alternate-background-color: {ALTERNATE_BACKGROUND};
}

QTreeWidget::branch {
    background: transparent;
    border: none;
    width: 16px;
    height: 16px;
    margin: 0px;
    padding: 0px;
}

/* Vertical continuation lines (items that have siblings below them) */
QTreeWidget::branch:has-siblings:!adjoins-item {
    background: transparent;
    border-image: none;
    /* Icon path set dynamically by TreeWidget */
}

/* T-junction: item with siblings that also has children (branch through) */
QTreeWidget::branch:has-siblings:adjoins-item {
    background: transparent;
    border-image: none;
    /* Icon path set dynamically by TreeWidget */
}

/* L-junction: last item in a group that has no children (end node) */
QTreeWidget::branch:!has-children:!has-siblings:adjoins-item {
    background: transparent;
    border-image: none;
    /* Icon path set dynamically by TreeWidget */
}

/* Expandable nodes - closed */
QTreeWidget::branch:has-children:closed {
    background: transparent;
    border-image: none;
    /* Icon path set dynamically by TreeWidget */
}

QTreeWidget::branch:has-children:closed:hover {
    background: transparent;
    border-image: none;
    /* Icon path set dynamically by TreeWidget */
}

/* Expandable nodes - open */
QTreeWidget::branch:has-children:open {
    background: transparent;
    border-image: none;
    /* Icon path set dynamically by TreeWidget */
}

QTreeWidget::branch:has-children:open:hover {
    background: transparent;
    border-image: none;
    /* Icon path set dynamically by TreeWidget */
}

/* T-junction: item with siblings that has children (closed) */
QTreeWidget::branch:closed:has-children:has-siblings {
    background: transparent;
    border-image: none;
    /* Icon path set dynamically by TreeWidget */
}

/* T-junction: item with siblings that has children (open) */
QTreeWidget::branch:open:has-children:has-siblings {
    background: transparent;
    border-image: none;
    /* Icon path set dynamically by TreeWidget */
}

/* L-junction: last item in a group that has children but is closed */
QTreeWidget::branch:has-children:!has-siblings:closed {
    background: transparent;
    border-image: none;
    /* Icon path set dynamically by TreeWidget */
}

/* L-junction: last item in a group that has children and is open */
QTreeWidget::branch:has-children:!has-siblings:open {
    background: transparent;
    border-image: none;
    /* Icon path set dynamically by TreeWidget */
}

QTreeWidget::item {
    padding: 2px 4px;
    border: none;
    min-height: 18px;
    color: {TEXT_COLOR};
    background: transparent;
}

QTreeWidget::item:selected {
    background-color: {BUTTON_CHECKED};
    color: {TEXT_CHECKED};
    border: none;
}

QTreeWidget::item:hover:!selected {
    background-color: rgba(255, 255, 255, 50);
    color: {TEXT_HOVER};
}

QTreeWidget::item:alternate {
    background-color: {TREE_ALTERNATE_BG};
}

/* Custom TreeWidget class support */
TreeWidget {
    outline: none;
    background-color: {WIDGET_BACKGROUND};
    color: {TEXT_COLOR};
    selection-background-color: {BUTTON_HOVER};
    show-decoration-selected: 1;
    gridline-color: transparent;
    qproperty-childRowColor: rgba(255, 255, 255, 0.04);
}

TreeWidget::item:selected {
    background-color: {BUTTON_CHECKED};
    color: {TEXT_CHECKED};
}

/* -- Separator Widget -- */
Separator {
    color: transparent;
    background: transparent;
    border: none;
    margin: 0px 2px 0px 2px;
    padding: 0px 2px 0px 2px;
}
Separator:hover {
    border: none;
}
Separator > QLabel {
    color: {TEXT_COLOR};
    font-size: 11px;
    background: {PANEL_BACKGROUND};
    border: none;
    padding: 0px 0px;
}
